{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Orbit",
  "version": "0.2.0",
  "identifier": "com.josefernando.orbit",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Orbit",
        "width": 1200,
        "height": 750,
        "minWidth": 900,
        "minHeight": 500
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEY0Mzg1RjI1QjFGREZBNkQKUldSdCt2MnhKVjg0OUlhSHRzU0lXd2U5d3JZOUpNNExXTmRzdkhkOVVMTjZnc3huZGRaTFFxSEwK",
      "endpoints": [
        "https://github.com/xinnaider/orbit/releases/latest/download/latest.json"
      ]
    }
  }
}
