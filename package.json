{
  "name": "orbit",
  "version": "0.2.4",
  "description": "Orbit — multi-session Claude Code agent dashboard",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "dev:mock": "vite dev --mode mock",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:rust": "cargo test --manifest-path tauri/Cargo.toml",
    "lint": "npm run lint:ui && npm run lint:tauri",
    "lint:ui": "eslint ui --max-warnings 0 && svelte-check --tsconfig ./tsconfig.json --fail-on-warnings",
    "lint:tauri": "cargo clippy --manifest-path tauri/Cargo.toml -- -D warnings",
    "format": "npm run format:ui && npm run format:tauri",
    "format:ui": "prettier --write \"ui/**/*.{ts,svelte,css}\"",
    "format:tauri": "cargo fmt --manifest-path tauri/Cargo.toml",
    "format:check": "npm run format:check:ui && npm run format:check:tauri",
    "format:check:ui": "prettier --check \"ui/**/*.{ts,svelte,css}\"",
    "format:check:tauri": "cargo fmt --manifest-path tauri/Cargo.toml --check",
    "tauri": "tauri",
    "tauri:dev": "tauri dev --config tauri/tauri.conf.json",
    "tauri:build": "tauri build --config tauri/tauri.conf.json",
    "tauri:icon": "tauri icon --config tauri/tauri.conf.json",
    "demo:gif": "node scripts/generate-demo-gif.mjs"
  },
  "license": "MIT",
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "diff": "^8.0.4",
    "highlight.js": "^11.11.1",
    "lucide-svelte": "^1.0.1",
    "marked": "^17.0.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@sveltejs/adapter-static": "^3.0.6",
    "@sveltejs/kit": "^2.9.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tauri-apps/cli": "^2",
    "@types/diff": "^7.0.2",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^9.0.0",
    "eslint-plugin-svelte": "^2.46.0",
    "gifenc": "^1.0.3",
    "globals": "^15.0.0",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "puppeteer": "^24.40.0",
    "sharp": "^0.34.5",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "svelte-eslint-parser": "^0.43.0",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "vitest": "^2.0.0"
  }
}
