---
// Fullscreen demo preview
---

<section class="demo" id="demo" data-section>
  <div class="demo-inner">
    <p class="label">see it in action</p>
    <h2 class="tagline">One window. <span class="accent">Every agent.</span></h2>
    <div class="frame">
      <img src="/demo.gif" alt="Orbit — multiple AI sessions running simultaneously" loading="lazy" />
    </div>
    <div class="providers">
      <span class="badge">Claude Code</span>
      <span class="badge">Codex</span>
      <span class="badge">OpenCode</span>
    </div>
  </div>
</section>

<style>
  .demo {
    min-height: 100vh;
    display: flex; align-items: center; justify-content: center;
    padding: 80px 48px;
    border-top: 1px solid var(--bd);
    position: relative; z-index: 1;
  }
  .demo-inner {
    max-width: 900px; width: 100%;
    display: flex; flex-direction: column; align-items: center;
  }
  .label {
    font-size: 9px; letter-spacing: 0.3em; text-transform: uppercase;
    color: var(--t3); margin-bottom: 16px;
  }
  .tagline {
    font-size: clamp(22px, 3.5vw, 34px);
    font-weight: 600; letter-spacing: 0.05em;
    color: var(--t1); text-align: center;
    margin-bottom: 40px; line-height: 1.3;
  }
  .accent { color: var(--ac); }
  .frame {
    width: 100%;
    border-radius: 8px;
    border: 1px solid rgba(0, 212, 126, 0.12);
    overflow: hidden; background: #080808;
  }
  .frame img {
    width: 100%; height: auto; display: block;
  }
  .providers {
    display: flex; align-items: center; gap: 8px;
    margin-top: 20px;
  }
  .badge {
    font-size: 10px; color: var(--ac); opacity: 0.7;
    letter-spacing: 0.04em;
    background: rgba(0, 212, 126, 0.06);
    border: 1px solid rgba(0, 212, 126, 0.15);
    border-radius: 4px; padding: 5px 10px;
  }

  @media (max-width: 768px) {
    .demo { padding: 60px 16px; min-height: auto; }
    .tagline { font-size: 22px; margin-bottom: 28px; }
    .providers { gap: 6px; flex-wrap: wrap; justify-content: center; }
    .badge { font-size: 10px; padding: 4px 10px; }
  }
</style>
