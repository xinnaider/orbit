---
// No props
---

<section class="hero">
  <!-- Stars (generated via JS for parallax layers) -->
  <div class="stars" id="stars-container" aria-hidden="true"></div>

  <!-- Orbit SVG -->
  <div class="orbit-wrap" aria-hidden="true">
    <svg viewBox="0 0 300 300" fill="none" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <filter id="glow">
          <feGaussianBlur stdDeviation="3" result="b"/>
          <feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge>
        </filter>
        <filter id="glow-sm">
          <feGaussianBlur stdDeviation="2" result="b"/>
          <feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge>
        </filter>
      </defs>

      <!-- Outer ring (clockwise) -->
      <g class="ring-outer">
        <ellipse cx="150" cy="150" rx="138" ry="53"
          stroke="#00d47e" stroke-width="1.2" opacity="0.35"
          transform="rotate(-38 150 150)"/>
      </g>

      <!-- Inner ring (counter-clockwise) -->
      <g class="ring-inner">
        <ellipse cx="150" cy="150" rx="88" ry="34"
          stroke="#00d47e" stroke-width="0.8" opacity="0.18"
          transform="rotate(-38 150 150)"/>
      </g>

      <!-- Satellite (follows outer ring) -->
      <g class="satellite">
        <circle cx="279" cy="117" r="4.5"
          fill="#00d47e" opacity="0.9" filter="url(#glow-sm)"/>
      </g>

      <!-- Central body -->
      <circle cx="150" cy="150" r="20" fill="#00d47e" opacity="0.10"/>
      <circle cx="150" cy="150" r="12" fill="#00d47e" opacity="0.15"/>
      <circle cx="150" cy="150" r="6"  fill="#00d47e" filter="url(#glow)"/>
    </svg>
  </div>

  <!-- Content -->
  <p class="eyebrow">● multi-agent dashboard</p>
  <h1>orbit</h1>
  <p class="subtitle">
    Manage multiple Claude Code sessions simultaneously.<br/>
    Real-time feed, persistent history, token tracking.
  </p>

  <div class="cta-group">
    <a href="https://github.com/xinnaider/orbit" class="btn-primary" id="github-star-btn">
      <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
        <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38
          0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13
          -.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66
          .07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15
          -.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27
          .68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12
          .51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48
          0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8
          c0-4.42-3.58-8-8-8z"/>
      </svg>
      <span class="btn-label">Star on GitHub</span>
      <span class="star-count" id="star-count" style="display:none"></span>
    </a>
    <div class="download-group">
      <a href="https://github.com/xinnaider/orbit/releases/latest" class="btn-secondary">
        <svg width="13" height="13" viewBox="0 0 88 88" fill="currentColor" aria-hidden="true" style="flex-shrink:0">
          <path d="M0 0h42v42H0V0z" opacity="0.9"/>
          <path d="M46 0h42v42H46V0z" opacity="0.9"/>
          <path d="M0 46h42v42H0V46z" opacity="0.9"/>
          <path d="M46 46h42v42H46V46z" opacity="0.9"/>
        </svg>
        Windows
        <span class="btn-tag">10+</span>
      </a>
      <a href="https://github.com/xinnaider/orbit/releases/latest" class="btn-secondary">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" style="flex-shrink:0">
          <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
        </svg>
        Linux
        <span class="btn-tag">AppImage</span>
      </a>
    </div>
    <div class="install-cmd" id="install-cmd">
      <span class="install-prompt">$</span>
      <span class="install-text">curl -fsSL https://raw.githubusercontent.com/xinnaider/orbit/master/scripts/install-linux.sh | bash</span>
      <button class="copy-btn" id="copy-btn" aria-label="Copy install command">
        <svg id="copy-icon" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
          <path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/>
        </svg>
        <svg id="check-icon" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="display:none">
          <polyline points="20 6 9 17 4 12"/>
        </svg>
      </button>
    </div>
    <span class="meta">Windows 10+ · Ubuntu 22.04+ · MIT</span>
  </div>

  <div class="preview-wrap">
    <div class="preview-frame">
      <img src="/demo.gif" alt="Orbit demo" class="preview-img" loading="lazy" />
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    position: relative; overflow: hidden;
    padding: 120px 24px 80px;
    text-align: center;
  }
  .stars { position: absolute; inset: 0; pointer-events: none; }

  .orbit-wrap {
    width: 300px; height: 300px;
    margin: 0 auto 44px; flex-shrink: 0;
    position: relative; z-index: 1;
  }
  .orbit-wrap svg { width: 100%; height: 100%; overflow: visible; }

  .eyebrow {
    font-size: 10px; letter-spacing: 0.25em;
    color: var(--ac); text-transform: uppercase;
    margin-bottom: 14px; position: relative; z-index: 1;
  }
  h1 {
    font-size: clamp(40px, 8vw, 72px);
    font-weight: 600; letter-spacing: 0.12em;
    color: var(--t0); line-height: 1.1; margin-bottom: 18px;
    position: relative; z-index: 1;
  }
  .subtitle {
    font-size: 13px; color: var(--t2);
    max-width: 420px; line-height: 1.8; margin-bottom: 36px;
    position: relative; z-index: 1;
  }

  .cta-group {
    display: flex; flex-direction: column;
    align-items: center; gap: 10px;
    position: relative; z-index: 1;
  }
  .btn-primary, .btn-secondary {
    display: inline-flex; align-items: center; gap: 8px;
    border-radius: 4px; font-family: var(--font);
    cursor: pointer; width: 100%;
    transition: all 0.2s;
  }
  .cta-group { width: fit-content; }
  .btn-primary {
    background: var(--ac-dim);
    border: 1px solid rgba(0, 212, 126, 0.4);
    color: var(--ac); padding: 12px 28px; font-size: 13px;
    letter-spacing: 0.06em;
  }
  .btn-primary:hover {
    background: rgba(0, 212, 126, 0.18);
    border-color: rgba(0, 212, 126, 0.7);
    box-shadow: 0 0 24px rgba(0, 212, 126, 0.12);
  }
  .star-count {
    background: rgba(0, 212, 126, 0.15);
    border: 1px solid rgba(0, 212, 126, 0.3);
    border-radius: 3px;
    padding: 1px 6px;
    font-size: 11px;
    letter-spacing: 0.04em;
    margin-left: 2px;
  }
  .download-group {
    display: flex; gap: 8px; width: 100%;
  }
  .download-group .btn-secondary {
    flex: 1; justify-content: center;
  }
  .btn-secondary {
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.08);
    color: #888; padding: 11px 20px; font-size: 12px;
    letter-spacing: 0.06em;
  }
  .btn-secondary:hover {
    background: rgba(255,255,255,0.06);
    border-color: rgba(255,255,255,0.15);
    color: var(--t1);
  }
  .btn-tag {
    font-size: 10px;
    color: var(--t3);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 3px;
    padding: 1px 5px;
    letter-spacing: 0.04em;
  }
  .install-cmd {
    display: flex; align-items: center; gap: 10px;
    width: 100%;
    background: rgba(0,0,0,0.35);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 4px;
    padding: 9px 14px;
    font-family: 'Courier New', Courier, monospace;
    font-size: 11px;
    overflow: hidden;
  }
  .install-prompt {
    color: var(--ac);
    flex-shrink: 0;
    user-select: none;
  }
  .install-text {
    color: var(--t2);
    flex: 1;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .copy-btn {
    flex-shrink: 0;
    background: none; border: none; cursor: pointer;
    color: var(--t3); padding: 2px;
    display: flex; align-items: center;
    transition: color 0.15s;
  }
  .copy-btn:hover { color: var(--ac); }
  .meta {
    margin-top: 4px;
    font-size: 10px; color: var(--t3); letter-spacing: 0.1em;
  }

  .preview-wrap {
    width: 100%;
    max-width: 900px;
    margin: 64px auto 0;
    position: relative;
    z-index: 1;
  }
  .preview-frame {
    border-radius: 8px;
    border: 1px solid rgba(0, 212, 126, 0.12);
    overflow: hidden;
    background: #0d0d0d;
  }
  .preview-img {
    width: 100%;
    height: auto;
    display: block;
  }

  @media (max-width: 768px) {
    .orbit-wrap { width: 220px; height: 220px; margin-bottom: 32px; }
    .subtitle { font-size: 12px; }
    .btn-primary, .btn-secondary { width: 100%; }
    .preview-wrap { margin-top: 48px; }
  }
  @media (max-width: 480px) {
    h1 { letter-spacing: 0.06em; }
    .orbit-wrap { width: 180px; height: 180px; }
  }
</style>

<script>
  // ── Star config ──────────────────────────────────────────
  const STAR_COUNT = 120;  // change this to add/remove stars
  const PARALLAX_LAYERS = 3; // number of depth layers

  // ── Generate stars ───────────────────────────────────────
  const container = document.getElementById('stars-container');
  if (container) {
    for (let i = 0; i < STAR_COUNT; i++) {
      const star = document.createElement('div');
      const layer = Math.floor(Math.random() * PARALLAX_LAYERS) + 1; // 1..3
      const size = layer === 1 ? 1 : layer === 2 ? 1.5 : 2; // closer = bigger
      const peakOpacity = 0.15 + Math.random() * 0.5;
      const duration = 3 + Math.random() * 5;
      const delay = Math.random() * 6;

      star.className = 'star';
      star.dataset.layer = String(layer);
      star.style.cssText = [
        `top:${(Math.random() * 100).toFixed(2)}%`,
        `left:${(Math.random() * 100).toFixed(2)}%`,
        `width:${size}px`,
        `height:${size}px`,
        `--d:${duration.toFixed(1)}s`,
        `--delay:${delay.toFixed(2)}s`,
        `--peak:${peakOpacity.toFixed(2)}`,
      ].join(';');

      container.appendChild(star);
    }
  }

  // ── Parallax on mousemove ────────────────────────────────
  const LAYER_SPEED = [0, 0.008, 0.018, 0.032]; // index = layer (0 unused)

  document.addEventListener('mousemove', (e) => {
    const cx = window.innerWidth / 2;
    const cy = window.innerHeight / 2;
    const dx = e.clientX - cx;
    const dy = e.clientY - cy;

    const stars = container?.querySelectorAll<HTMLElement>('.star[data-layer]');
    stars?.forEach((star) => {
      const layer = Number(star.dataset.layer);
      const speed = LAYER_SPEED[layer] ?? 0.01;
      star.style.transform = `translate(${dx * speed}px, ${dy * speed}px)`;
    });
  });

  // ── GitHub star count (cached 1h in localStorage) ────────
  const CACHE_KEY = 'orbit_gh_stars';
  const CACHE_TTL = 60 * 60 * 1000; // 1 hour

  function showStars(count: number) {
    const el = document.getElementById('star-count');
    if (el) {
      el.textContent = count >= 1000 ? `${(count / 1000).toFixed(1)}k` : String(count);
      el.style.display = 'inline';
    }
  }

  try {
    const cached = localStorage.getItem(CACHE_KEY);
    if (cached) {
      const { count, ts } = JSON.parse(cached);
      if (Date.now() - ts < CACHE_TTL) {
        showStars(count);
      } else {
        throw new Error('stale');
      }
    } else {
      throw new Error('miss');
    }
  } catch {
    fetch('https://api.github.com/repos/xinnaider/orbit')
      .then((r) => r.json())
      .then((data) => {
        const count = data?.stargazers_count;
        if (typeof count === 'number') {
          showStars(count);
          localStorage.setItem(CACHE_KEY, JSON.stringify({ count, ts: Date.now() }));
        }
      })
      .catch(() => { /* silently ignore if API fails */ });
  }

  // ── Copy install command ─────────────────────────────────
  const copyBtn = document.getElementById('copy-btn');
  const copyIcon = document.getElementById('copy-icon');
  const checkIcon = document.getElementById('check-icon');
  const CMD = 'curl -fsSL https://raw.githubusercontent.com/xinnaider/orbit/master/scripts/install-linux.sh | bash';

  copyBtn?.addEventListener('click', () => {
    navigator.clipboard.writeText(CMD).then(() => {
      if (copyIcon) copyIcon.style.display = 'none';
      if (checkIcon) checkIcon.style.display = 'block';
      setTimeout(() => {
        if (copyIcon) copyIcon.style.display = 'block';
        if (checkIcon) checkIcon.style.display = 'none';
      }, 2000);
    }).catch(() => {});
  });
</script>
